# Biến môi trường mẫu cho docker compose. Sao chép sang .env trước khi `docker compose up -d`.
# `.env` đã ở .gitignore (qua .dockerignore + .gitignore mặc định của Astro).

# Cổng nghe ở host. Đứng sau Cloudflare Tunnel / proxy thì để mặc định.
HTTP_PORT=8080

# Khi dùng `--profile caddy` để tự lo TLS:
DOMAIN=dancumang.vn
ACME_EMAIL=admin@dancumang.vn
