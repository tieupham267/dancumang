---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Compass } from "lucide-react";
---

<BaseLayout title="Không tìm thấy trang — Dân Cư Mạng" description="Trang bạn tìm không tồn tại.">
  <main class="not-found">
    <div class="nf-box">
      <div class="nf-glyph" aria-hidden="true">
        <span class="nf-code">404</span>
        <span class="nf-mark">
          <Compass className="nf-icon" strokeWidth={2} />
        </span>
      </div>

      <h1>Không tìm thấy trang</h1>
      <p>
        Bạn đi nhầm đường rồi. Có thể link đã đổi, hoặc trang chưa tồn tại.
        Thử vài lựa chọn dưới đây nhé.
      </p>

      <div class="nf-actions">
        <a href="/" class="btn btn-primary">Về trang chủ</a>
        <a href="/khoa-hoc/" class="btn btn-ghost">Vào khóa học</a>
        <a href="/blog/" class="btn btn-ghost">Đọc cảnh báo</a>
      </div>

      <p class="nf-meta">
        Nếu bạn nghĩ đây là lỗi, hãy báo cho chúng tôi qua
        <a href="https://github.com/tieupham267/dancumang/issues">GitHub Issues</a>.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    max-width: 720px;
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }

  .nf-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 64px 32px;
    box-shadow: var(--shadow-card);
  }

  .nf-glyph {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .nf-code {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 4rem + 4vw, 5.5rem);
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nf-mark {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--primary-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .nf-mark :global(.nf-icon) {
    width: 28px;
    height: 28px;
    color: var(--primary);
  }

  .nf-box h1 {
    font-size: clamp(1.6rem, 1.2rem + 1.4vw, 2.2rem);
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--ink-strong);
    letter-spacing: -0.02em;
  }

  .nf-box > p {
    color: var(--ink-muted);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 32px;
    font-size: 1.02rem;
  }

  .nf-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .nf-meta {
    font-size: 0.88rem;
    color: var(--ink-faint);
  }

  .nf-meta a {
    color: var(--primary);
    font-weight: 600;
  }

  @media (max-width: 520px) {
    .nf-box { padding: 48px 24px; }
    .nf-glyph { flex-direction: column; gap: 12px; }
    .nf-actions .btn { width: 100%; }
  }
</style>
