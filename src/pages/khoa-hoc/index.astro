---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  LockKeyhole,
  Fish,
  Users,
  Smartphone,
  BookOpen,
  Clock,
  ArrowRight,
  GraduationCap,
} from "lucide-react";
import type { ComponentType } from "react";

type LucideIcon = ComponentType<{ className?: string; "aria-hidden"?: boolean; strokeWidth?: number }>;

const allLessons = (await getCollection("courses"))
  .filter((lesson) => !lesson.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

interface ModuleGroup {
  id: number;
  title: string;
  description: string;
  Icon: LucideIcon;
  lessons: typeof allLessons;
}

const moduleIcons: Record<string, LucideIcon> = {
  lock: LockKeyhole,
  alert: Fish,
  users: Users,
  shield: Smartphone,
};

const modulesMap = new Map<number, ModuleGroup>();
for (const lesson of allLessons) {
  const id = lesson.data.module.id;
  const existing = modulesMap.get(id);
  if (existing) {
    existing.lessons.push(lesson);
  } else {
    modulesMap.set(id, {
      id,
      title: lesson.data.module.title,
      description: lesson.data.module.description,
      Icon: moduleIcons[lesson.data.module.icon] ?? BookOpen,
      lessons: [lesson],
    });
  }
}

const moduleList = Array.from(modulesMap.values()).sort((a, b) => a.id - b.id);
const totalLessons = allLessons.length;
---

<BaseLayout
  title="Khóa học bảo mật — Dân Cư Mạng"
  description="Học bảo mật từ con số 0, miễn phí, bằng tiếng Việt. 4 module: mật khẩu, lừa đảo, mạng xã hội, thiết bị."
>
  <main class="courses-page">
    <header class="courses-header">
      <span class="eyebrow">
        <GraduationCap className="eyebrow-icon" aria-hidden="true" strokeWidth={2.2} />
        Khóa học
      </span>
      <h1>Bảo mật không khó như bạn nghĩ</h1>
      <p class="lede">
        Mỗi bài học chỉ mất 5–10 phút. Bắt đầu từ Module 1 và đi theo thứ tự,
        hoặc chọn chủ đề bạn quan tâm trước. Hoàn toàn miễn phí — không cần tài khoản.
      </p>

      <div class="header-stats">
        <div class="hstat">
          <strong>{totalLessons}</strong>
          <span>bài học</span>
        </div>
        <div class="hstat">
          <strong>{moduleList.length}</strong>
          <span>module</span>
        </div>
        <div class="hstat">
          <strong>~{moduleList.length * 8}'</strong>
          <span>tổng thời gian</span>
        </div>
      </div>
    </header>

    {moduleList.map((mod) => {
      const ModIcon = mod.Icon;
      return (
        <section class="module-card" style={`--mod: var(--module-${mod.id});`}>
          <div class="module-card-head">
            <div class="module-head-left">
              <span class="module-mark">
                <ModIcon className="module-icon" aria-hidden={true} strokeWidth={2} />
              </span>
              <div>
                <span class="module-label">Module {String(mod.id).padStart(2, "0")}</span>
                <h2>{mod.title}</h2>
                <p class="module-description">{mod.description}</p>
              </div>
            </div>
            <span class="module-count">
              {mod.lessons.length} <span>bài</span>
            </span>
          </div>

          <ol class="lesson-list">
            {mod.lessons.map((lesson) => {
              const hasQuiz = Array.isArray(lesson.data.quiz) && lesson.data.quiz.length > 0;
              return (
                <li>
                  <a href={`/khoa-hoc/${lesson.id}`} class="lesson-link">
                    <span class="lesson-order">{String(lesson.data.order).padStart(2, "0")}</span>
                    <span class="lesson-info">
                      <span class="lesson-title">{lesson.data.title}</span>
                      <span class="lesson-meta">
                        <span class="lesson-duration">
                          <Clock className="meta-icon" aria-hidden={true} strokeWidth={2.2} />
                          {lesson.data.duration}
                        </span>
                        {hasQuiz && <span class="quiz-badge">Có quiz</span>}
                      </span>
                    </span>
                    <ArrowRight className="lesson-arrow" aria-hidden={true} strokeWidth={2} />
                  </a>
                </li>
              );
            })}
          </ol>
        </section>
      );
    })}
  </main>
</BaseLayout>

<style>
  .courses-page {
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 64px) 24px clamp(64px, 8vw, 96px);
  }

  .courses-header {
    margin-bottom: 56px;
  }

  .eyebrow-icon { width: 14px; height: 14px; }

  .courses-header h1 {
    font-size: clamp(2rem, 1.2rem + 2.4vw, 3rem);
    font-weight: 800;
    margin: 16px 0 18px;
    line-height: 1.1;
    letter-spacing: -0.025em;
  }

  .lede {
    color: var(--ink-muted);
    line-height: 1.7;
    font-size: 1.05rem;
    max-width: 640px;
    margin-bottom: 32px;
  }

  .header-stats {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    padding: 16px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .hstat {
    padding: 0 22px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hstat:first-child { padding-left: 0; }
  .hstat:last-child { padding-right: 0; border-right: none; }

  .hstat strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--primary);
    line-height: 1;
  }

  .hstat span {
    font-size: 0.78rem;
    color: var(--ink-muted);
  }

  .module-card {
    --mod: var(--primary);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 32px;
    margin-bottom: 28px;
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--duration-normal);
  }

  .module-card:hover { box-shadow: var(--shadow-card); }

  .module-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--mod);
  }

  .module-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }

  .module-head-left {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    flex: 1;
  }

  .module-mark {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: color-mix(in oklab, var(--mod) 12%, transparent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .module-mark :global(.module-icon) {
    width: 28px;
    height: 28px;
    color: var(--mod);
  }

  .module-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--mod);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .module-card-head h2 {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 4px 0 6px;
    color: var(--ink-strong);
  }

  .module-description {
    color: var(--ink-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .module-count {
    flex-shrink: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    padding: 8px 14px;
    background: color-mix(in oklab, var(--mod) 10%, transparent);
    color: var(--mod);
    border-radius: var(--radius-pill);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
  }

  .module-count span {
    font-size: 0.78rem;
    font-weight: 600;
  }

  .lesson-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .lesson-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 14px 16px;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background var(--duration-fast);
  }

  .lesson-link:hover {
    background: color-mix(in oklab, var(--mod) 6%, transparent);
  }

  .lesson-order {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--mod);
    opacity: 0.55;
    min-width: 28px;
  }

  .lesson-info { min-width: 0; }

  .lesson-title {
    font-weight: 600;
    font-size: 0.98rem;
    display: block;
    color: var(--ink-strong);
    line-height: 1.4;
  }

  .lesson-meta {
    font-size: 0.78rem;
    color: var(--ink-muted);
    margin-top: 4px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .lesson-duration {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .lesson-duration :global(.meta-icon) {
    width: 13px;
    height: 13px;
  }

  .quiz-badge {
    background: var(--success-soft);
    color: #047857;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  .lesson-link :global(.lesson-arrow) {
    color: var(--mod);
    width: 18px;
    height: 18px;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--duration-fast), transform var(--duration-fast) var(--ease-out);
  }

  .lesson-link:hover :global(.lesson-arrow) {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 600px) {
    .module-card { padding: 24px 20px; }
    .module-card-head {
      flex-direction: column;
      gap: 16px;
    }
    .module-mark { width: 44px; height: 44px; }
    .module-mark :global(.module-icon) { width: 22px; height: 22px; }
    .lesson-link { padding: 12px 10px; gap: 12px; }
    .header-stats { flex-wrap: wrap; }
  }
</style>
